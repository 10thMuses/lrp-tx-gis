# Claude Code session env. Copy to .env and fill in.
# .env is gitignored.
#
# In chat mode (Anthropic web/mobile interface) this file is unused — credentials
# live in /mnt/project/CREDENTIALS.md and the chat container has its own paths.

# GitHub fine-grained PAT for direct API ops (most git ops use local credential helper).
GITHUB_PAT=

# Netlify Personal Access Token for scripts/deploy.sh JSON-RPC path.
# Mint at https://app.netlify.com/user/applications#personal-access-tokens
# Without this, deploy.sh exits 3 and falls through to in-chat Netlify MCP path.
NETLIFY_PAT=

# Path overrides. Defaults match chat-mode mounts; override for Claude Code.
# Most Claude Code users want LRP_PROJECT_DIR=. and the others unset.
LRP_PROJECT_DIR=.
LRP_DIST_DIR=./dist
LRP_UPLOADS_DIR=./uploads
